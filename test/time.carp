(load "Test.carp")
(load "../time.carp")
(use Test)

(deftest test
  (assert-equal test
    2024
    @(Datetime.year &(Datetime.date 2024 3 15))
    "date creates correct year")
  (assert-equal test
    3
    @(Datetime.month &(Datetime.date 2024 3 15))
    "date creates correct month")
  (assert-equal test
    15
    @(Datetime.day &(Datetime.date 2024 3 15))
    "date creates correct day")
  (assert-true test
    (Maybe.nothing? (Datetime.hours &(Datetime.date 2024 3 15)))
    "date has no hours")
  (assert-true test
    (Maybe.nothing? (Datetime.minutes &(Datetime.date 2024 3 15)))
    "date has no minutes")
  (assert-true test
    (Maybe.nothing? (Datetime.seconds &(Datetime.date 2024 3 15)))
    "date has no seconds")

  (assert-true test
    (Datetime.leap? &(Datetime.date 2000 1 1))
    "2000 is a leap year")
  (assert-true test
    (Datetime.leap? &(Datetime.date 2024 1 1))
    "2024 is a leap year")
  (assert-false test
    (Datetime.leap? &(Datetime.date 1900 1 1))
    "1900 is not a leap year")
  (assert-false test
    (Datetime.leap? &(Datetime.date 2023 1 1))
    "2023 is not a leap year")

  (assert-equal test
    1
    (Datetime.to-ordinal &(Datetime.date 1 1 1))
    "ordinal of 0001-01-01 is 1")
  (assert-equal test
    730120
    (Datetime.to-ordinal &(Datetime.date 2000 1 1))
    "ordinal of 2000-01-01")
  (assert-equal test
    &(Datetime.date 2000 1 1)
    &(Datetime.from-ordinal 730120)
    "from-ordinal roundtrips with 2000-01-01")
  (assert-equal test
    &(Datetime.date 1 1 1)
    &(Datetime.from-ordinal 1)
    "from-ordinal of 1 is 0001-01-01")

  (assert-equal test
    4
    (Datetime.weekday &(Datetime.date 2024 3 15))
    "2024-03-15 is weekday 4 (Friday)")
  (assert-equal test
    5
    (Datetime.isoweekday &(Datetime.date 2024 3 15))
    "2024-03-15 is isoweekday 5 (Friday)")
  (assert-equal test
    0
    (Datetime.weekday &(Datetime.date 2024 3 18))
    "2024-03-18 is weekday 0 (Monday)")
  (assert-equal test
    1
    (Datetime.isoweekday &(Datetime.date 2024 3 18))
    "2024-03-18 is isoweekday 1 (Monday)")

  (assert-equal test
    1
    (Datetime.yearday &(Datetime.date 2024 1 1))
    "Jan 1 is yearday 1")
  (assert-equal test
    60
    (Datetime.yearday &(Datetime.date 2024 2 29))
    "Feb 29 in leap year is yearday 60")
  (assert-equal test
    365
    (Datetime.yearday &(Datetime.date 2023 12 31))
    "Dec 31 in non-leap year is yearday 365")
  (assert-equal test
    61
    (Datetime.yearday &(Datetime.date 2024 3 1))
    "March 1 in a leap year is yearday 61 (leap day counted)")
  (assert-equal test
    366
    (Datetime.yearday &(Datetime.date 2024 12 31))
    "Dec 31 in a leap year is yearday 366")
  (assert-equal test
    60
    (Datetime.yearday &(Datetime.date 2023 3 1))
    "March 1 in a non-leap year is yearday 60")

  (assert-equal test
    &@"Friday"
    &(Datetime.weekday-string &(Datetime.date 2024 3 15))
    "weekday-string of Friday")
  (assert-equal test
    &@"Fri"
    &(Datetime.weekday-short-string &(Datetime.date 2024 3 15))
    "weekday-short-string of Friday")
  (assert-equal test
    &@"Monday"
    &(Datetime.weekday-string &(Datetime.date 2024 3 18))
    "weekday-string of Monday")

  (assert-equal test
    &@"March"
    &(Datetime.month-string &(Datetime.date 2024 3 15))
    "month-string of March")
  (assert-equal test
    &@"Mar"
    &(Datetime.month-short-string &(Datetime.date 2024 3 15))
    "month-short-string of March")
  (assert-equal test
    &@"January"
    &(Datetime.month-string &(Datetime.date 2024 1 1))
    "month-string of January")
  (assert-equal test
    &@"December"
    &(Datetime.month-string &(Datetime.date 2024 12 25))
    "month-string of December")

  (assert-equal test
    &@"2024-03-15"
    &(Datetime.isoformat &(Datetime.date 2024 3 15))
    "isoformat of 2024-03-15")
  (assert-equal test
    &@"0001-01-01"
    &(Datetime.isoformat &(Datetime.date 1 1 1))
    "isoformat zero-pads year")
  (assert-equal test
    &@"00:00:00"
    &(Datetime.isotime &(Datetime.date 2024 3 15))
    "isotime defaults to 00:00:00 for date-only")
  (assert-equal test
    &@"14:30:45"
    &(Datetime.isotime
      &(Datetime.init 2024
                      3
                      15
                      (Maybe.Just 14)
                      (Maybe.Just 30)
                      (Maybe.Just 45)
                      (Maybe.Nothing)
                      (Maybe.Nothing)))
    "isotime with explicit time")

  (assert-true test
    (Datetime.utc? &(Datetime.date 2024 3 15))
    "date with no timezone is utc")
  (assert-true test
    (Datetime.utc?
      &(Datetime.init 2024
                      3
                      15
                      (Maybe.Nothing)
                      (Maybe.Nothing)
                      (Maybe.Nothing)
                      (Maybe.Nothing)
                      (Maybe.Just @&Timezone.utc)))
    "date with UTC timezone is utc")
  (assert-true test
    (Datetime.utc?
      &(Datetime.init 2024
                      3
                      15
                      (Maybe.Nothing)
                      (Maybe.Nothing)
                      (Maybe.Nothing)
                      (Maybe.Nothing)
                      (Maybe.Just (Timezone.init @"utc" 0l false))))
    "date with lowercase utc timezone is utc")
  (assert-true test
    (Datetime.utc?
      &(Datetime.init 2024
                      3
                      15
                      (Maybe.Nothing)
                      (Maybe.Nothing)
                      (Maybe.Nothing)
                      (Maybe.Nothing)
                      (Maybe.Just (Timezone.init @"Utc" 0l false))))
    "date with mixed case Utc timezone is utc")
  (assert-false test
    (Datetime.utc?
      &(Datetime.init 2024
                      3
                      15
                      (Maybe.Nothing)
                      (Maybe.Nothing)
                      (Maybe.Nothing)
                      (Maybe.Nothing)
                      (Maybe.Just (Timezone.init @"EST" -18000l false))))
    "date with non-UTC timezone is not utc")

  (assert-true test
    (= &(Datetime.date 2024 3 15) &(Datetime.date 2024 3 15))
    "equal dates are equal")
  (assert-false test
    (= &(Datetime.date 2024 3 15) &(Datetime.date 2024 3 16))
    "different dates are not equal")

  (assert-equal test
    0
    (Datetime.to-unix-timestamp
      &(Datetime.init 1970
                      1
                      1
                      (Maybe.Just 0)
                      (Maybe.Just 0)
                      (Maybe.Just 0)
                      (Maybe.Nothing)
                      (Maybe.Nothing)))
    "unix epoch is timestamp 0")
  ; midnight EST (UTC-5) is 05:00 UTC, i.e. 18000 seconds past the epoch; the
  ; timezone offset must be subtracted from the wall-clock, not added
  (assert-equal test
    18000
    (Datetime.to-unix-timestamp
      &(Datetime.init 1970
                      1
                      1
                      (Maybe.Just 0)
                      (Maybe.Just 0)
                      (Maybe.Just 0)
                      (Maybe.Nothing)
                      (Maybe.Just (Timezone.init @"EST" -18000l false))))
    "to-unix-timestamp subtracts a negative (west-of-UTC) offset")
  ; 1970-01-02 00:00 at UTC+5 is 1970-01-01 19:00 UTC = 86400 - 18000 = 68400
  (assert-equal test
    68400
    (Datetime.to-unix-timestamp
      &(Datetime.init 1970
                      1
                      2
                      (Maybe.Just 0)
                      (Maybe.Just 0)
                      (Maybe.Just 0)
                      (Maybe.Nothing)
                      (Maybe.Just (Timezone.init @"PKT" 18000l false))))
    "to-unix-timestamp subtracts a positive (east-of-UTC) offset")
  (assert-equal test
    &(Datetime.init 1970
                    1
                    1
                    (Maybe.Just 0)
                    (Maybe.Just 0)
                    (Maybe.Just 0)
                    (Maybe.Nothing)
                    (Maybe.Nothing))
    &(Datetime.from-unix-timestamp 0)
    "from-unix-timestamp 0 is epoch")
  ; Feb 29 leap year round-trip (1972 is a leap year, ts = 68169600)
  (assert-equal test
    &(Datetime.init 1972
                    2
                    29
                    (Maybe.Just 0)
                    (Maybe.Just 0)
                    (Maybe.Just 0)
                    (Maybe.Nothing)
                    (Maybe.Nothing))
    &(Datetime.from-unix-timestamp
      (Datetime.to-unix-timestamp
        &(Datetime.init 1972
                        2
                        29
                        (Maybe.Just 0)
                        (Maybe.Just 0)
                        (Maybe.Just 0)
                        (Maybe.Nothing)
                        (Maybe.Nothing))))
    "from-unix-timestamp round-trips Feb 29 in leap year")
  ; March 1 leap year round-trip (month >= 3 needs leap-day offset in to-unix)
  (assert-equal test
    &(Datetime.init 1972
                    3
                    1
                    (Maybe.Just 0)
                    (Maybe.Just 0)
                    (Maybe.Just 0)
                    (Maybe.Nothing)
                    (Maybe.Nothing))
    &(Datetime.from-unix-timestamp
      (Datetime.to-unix-timestamp
        &(Datetime.init 1972
                        3
                        1
                        (Maybe.Just 0)
                        (Maybe.Just 0)
                        (Maybe.Just 0)
                        (Maybe.Nothing)
                        (Maybe.Nothing))))
    "from-unix-timestamp round-trips March 1 in leap year")

  ; known UTC values, cross-checked against the standard Unix epoch. 1971-01-01
  ; is one non-leap year (365 days) past the epoch; this input previously
  ; SIGABRTed in both directions.
  (assert-equal test
    31536000
    (Datetime.to-unix-timestamp
      &(Datetime.init 1971
                      1
                      1
                      (Maybe.Just 0)
                      (Maybe.Just 0)
                      (Maybe.Just 0)
                      (Maybe.Nothing)
                      (Maybe.Nothing)))
    "to-unix-timestamp of 1971-01-01")
  (assert-equal test
    &(Datetime.init 1971
                    1
                    1
                    (Maybe.Just 0)
                    (Maybe.Just 0)
                    (Maybe.Just 0)
                    (Maybe.Nothing)
                    (Maybe.Nothing))
    &(Datetime.from-unix-timestamp 31536000)
    "from-unix-timestamp of 1971-01-01")
  ; 2023-12-31 23:59:59 (one second before 2024) previously produced a day-ZERO
  ; date of 2024-1-0
  (assert-equal test
    1704067199
    (Datetime.to-unix-timestamp
      &(Datetime.init 2023
                      12
                      31
                      (Maybe.Just 23)
                      (Maybe.Just 59)
                      (Maybe.Just 59)
                      (Maybe.Nothing)
                      (Maybe.Nothing)))
    "to-unix-timestamp of 2023-12-31 23:59:59")
  (assert-equal test
    &(Datetime.init 2023
                    12
                    31
                    (Maybe.Just 23)
                    (Maybe.Just 59)
                    (Maybe.Just 59)
                    (Maybe.Nothing)
                    (Maybe.Nothing))
    &(Datetime.from-unix-timestamp 1704067199)
    "from-unix-timestamp of 2023-12-31 23:59:59")
  ; 1000000000 is 2001-09-09 01:46:40 UTC
  (assert-equal test
    1000000000
    (Datetime.to-unix-timestamp
      &(Datetime.init 2001
                      9
                      9
                      (Maybe.Just 1)
                      (Maybe.Just 46)
                      (Maybe.Just 40)
                      (Maybe.Nothing)
                      (Maybe.Nothing)))
    "to-unix-timestamp of 2001-09-09 01:46:40")
  (assert-equal test
    &(Datetime.init 2001
                    9
                    9
                    (Maybe.Just 1)
                    (Maybe.Just 46)
                    (Maybe.Just 40)
                    (Maybe.Nothing)
                    (Maybe.Nothing))
    &(Datetime.from-unix-timestamp 1000000000)
    "from-unix-timestamp of 2001-09-09 01:46:40")
  ; the 32-bit time_t maximum: 2038-01-19 03:14:07 UTC = 2147483647
  (assert-equal test
    2147483647
    (Datetime.to-unix-timestamp
      &(Datetime.init 2038
                      1
                      19
                      (Maybe.Just 3)
                      (Maybe.Just 14)
                      (Maybe.Just 7)
                      (Maybe.Nothing)
                      (Maybe.Nothing)))
    "to-unix-timestamp at the 32-bit boundary")
  (assert-equal test
    &(Datetime.init 2038
                    1
                    19
                    (Maybe.Just 3)
                    (Maybe.Just 14)
                    (Maybe.Just 7)
                    (Maybe.Nothing)
                    (Maybe.Nothing))
    &(Datetime.from-unix-timestamp 2147483647)
    "from-unix-timestamp at the 32-bit boundary")
  ; negative timestamps (pre-1970). / and mod truncate toward zero in Carp, so
  ; the time-of-day must be floored to stay in 0..86399.
  (assert-equal test
    -1
    (Datetime.to-unix-timestamp
      &(Datetime.init 1969
                      12
                      31
                      (Maybe.Just 23)
                      (Maybe.Just 59)
                      (Maybe.Just 59)
                      (Maybe.Nothing)
                      (Maybe.Nothing)))
    "to-unix-timestamp one second before the epoch is -1")
  (assert-equal test
    &(Datetime.init 1969
                    12
                    31
                    (Maybe.Just 23)
                    (Maybe.Just 59)
                    (Maybe.Just 59)
                    (Maybe.Nothing)
                    (Maybe.Nothing))
    &(Datetime.from-unix-timestamp -1)
    "from-unix-timestamp of -1 is one second before the epoch")
  (assert-equal test
    &(Datetime.init 1969
                    12
                    31
                    (Maybe.Just 0)
                    (Maybe.Just 0)
                    (Maybe.Just 0)
                    (Maybe.Nothing)
                    (Maybe.Nothing))
    &(Datetime.from-unix-timestamp -86400)
    "from-unix-timestamp of -86400 is exactly one day before the epoch")
  (assert-equal test
    &(Datetime.init 1969
                    6
                    15
                    (Maybe.Just 12)
                    (Maybe.Just 30)
                    (Maybe.Just 45)
                    (Maybe.Nothing)
                    (Maybe.Nothing))
    &(Datetime.from-unix-timestamp
      (Datetime.to-unix-timestamp
        &(Datetime.init 1969
                        6
                        15
                        (Maybe.Just 12)
                        (Maybe.Just 30)
                        (Maybe.Just 45)
                        (Maybe.Nothing)
                        (Maybe.Nothing))))
    "from-unix-timestamp round-trips a pre-1970 date with a time-of-day")
  ; leap-day boundary, cross-checked against known UTC values: 1972-02-29 is
  ; 68169600 and the following day 1972-03-01 is exactly 86400 seconds later
  (assert-equal test
    68169600
    (Datetime.to-unix-timestamp
      &(Datetime.init 1972
                      2
                      29
                      (Maybe.Just 0)
                      (Maybe.Just 0)
                      (Maybe.Just 0)
                      (Maybe.Nothing)
                      (Maybe.Nothing)))
    "to-unix-timestamp of the leap day 1972-02-29")
  (assert-equal test
    &(Datetime.init 1972
                    2
                    29
                    (Maybe.Just 0)
                    (Maybe.Just 0)
                    (Maybe.Just 0)
                    (Maybe.Nothing)
                    (Maybe.Nothing))
    &(Datetime.from-unix-timestamp 68169600)
    "from-unix-timestamp of the leap day 1972-02-29")
  (assert-equal test
    68256000
    (Datetime.to-unix-timestamp
      &(Datetime.init 1972
                      3
                      1
                      (Maybe.Just 0)
                      (Maybe.Just 0)
                      (Maybe.Just 0)
                      (Maybe.Nothing)
                      (Maybe.Nothing)))
    "to-unix-timestamp of the day after the leap day 1972-03-01")

  (assert-equal test
    &@"00:00:30"
    &(Datetime.isotime
      &(Datetime.add-seconds
        &(Datetime.init 2024
                        1
                        1
                        (Maybe.Just 0)
                        (Maybe.Just 0)
                        (Maybe.Just 0)
                        (Maybe.Nothing)
                        (Maybe.Nothing))
        30))
    "add 30 seconds")
  (assert-equal test
    &@"00:01:00"
    &(Datetime.isotime
      &(Datetime.add-seconds
        &(Datetime.init 2024
                        1
                        1
                        (Maybe.Just 0)
                        (Maybe.Just 0)
                        (Maybe.Just 30)
                        (Maybe.Nothing)
                        (Maybe.Nothing))
        30))
    "add 30 seconds wraps to next minute")
  (assert-equal test
    &@"01:00:00"
    &(Datetime.isotime
      &(Datetime.add-seconds
        &(Datetime.init 2024
                        1
                        1
                        (Maybe.Just 0)
                        (Maybe.Just 0)
                        (Maybe.Just 0)
                        (Maybe.Nothing)
                        (Maybe.Nothing))
        3600))
    "add 3600 seconds is one hour")

  (assert-equal test
    &@"2024-03-15"
    &(Datetime.strftime &(Datetime.date 2024 3 15) "%Y-%m-%d")
    "strftime %Y-%m-%d")
  (assert-equal test
    &@"Fri"
    &(Datetime.strftime &(Datetime.date 2024 3 15) "%a")
    "strftime %a abbreviated weekday")
  (assert-equal test
    &@"Friday"
    &(Datetime.strftime &(Datetime.date 2024 3 15) "%A")
    "strftime %A full weekday")
  (assert-equal test
    &@"Mar"
    &(Datetime.strftime &(Datetime.date 2024 3 15) "%b")
    "strftime %b abbreviated month")
  (assert-equal test
    &@"March"
    &(Datetime.strftime &(Datetime.date 2024 3 15) "%B")
    "strftime %B full month")

  (assert-equal test
    &@"+0530"
    &(Datetime.strftime
      &(Datetime.init 2024
                      3
                      15
                      (Maybe.Just 14)
                      (Maybe.Just 30)
                      (Maybe.Just 0)
                      (Maybe.Nothing)
                      (Maybe.Just (Timezone.init @"IST" 19800l false)))
      "%z")
    "strftime %z formats half-hour offset correctly")
  (assert-equal test
    &@"-0800"
    &(Datetime.strftime
      &(Datetime.init 2024
                      3
                      15
                      (Maybe.Just 6)
                      (Maybe.Just 0)
                      (Maybe.Just 0)
                      (Maybe.Nothing)
                      (Maybe.Just (Timezone.init @"PST" -28800l false)))
      "%z")
    "strftime %z formats negative whole-hour offset")
  (assert-equal test
    &@"+0000"
    &(Datetime.strftime
      &(Datetime.init 2024
                      3
                      15
                      (Maybe.Just 12)
                      (Maybe.Just 0)
                      (Maybe.Just 0)
                      (Maybe.Nothing)
                      (Maybe.Just @&Timezone.utc))
      "%z")
    "strftime %z formats UTC as +0000")
  (assert-equal test
    &@"12"
    &(Datetime.strftime
      &(Datetime.init 2024
                      3
                      15
                      (Maybe.Just 0)
                      (Maybe.Just 0)
                      (Maybe.Just 0)
                      (Maybe.Nothing)
                      (Maybe.Nothing))
      "%I")
    "strftime %I renders midnight (hour 0) as 12")
  (assert-equal test
    &@"12"
    &(Datetime.strftime
      &(Datetime.init 2024
                      3
                      15
                      (Maybe.Just 12)
                      (Maybe.Just 0)
                      (Maybe.Just 0)
                      (Maybe.Nothing)
                      (Maybe.Nothing))
      "%I")
    "strftime %I renders noon (hour 12) as 12")
  (assert-equal test
    &@"01"
    &(Datetime.strftime
      &(Datetime.init 2024
                      3
                      15
                      (Maybe.Just 13)
                      (Maybe.Just 0)
                      (Maybe.Just 0)
                      (Maybe.Nothing)
                      (Maybe.Nothing))
      "%I")
    "strftime %I renders 13:00 as 01")
  (assert-equal test
    &@"11"
    &(Datetime.strftime
      &(Datetime.init 2024
                      3
                      15
                      (Maybe.Just 23)
                      (Maybe.Just 0)
                      (Maybe.Just 0)
                      (Maybe.Nothing)
                      (Maybe.Nothing))
      "%I")
    "strftime %I renders 23:00 as 11")
  (assert-equal test
    &@"061"
    &(Datetime.strftime &(Datetime.date 2024 3 1) "%j")
    "strftime %j is leap-aware after February")
  (assert-equal test
    &@"366"
    &(Datetime.strftime &(Datetime.date 2024 12 31) "%j")
    "strftime %j reaches 366 on the last day of a leap year")
  (assert-equal test
    &@"060"
    &(Datetime.strftime &(Datetime.date 2023 3 1) "%j")
    "strftime %j stays 60 for March 1 in a non-leap year")
  (assert-equal test
    &@"00"
    &(Datetime.strftime &(Datetime.date 2024 1 1) "%U")
    "strftime %U puts days before the first Sunday in week 0")
  (assert-equal test
    &@"01"
    &(Datetime.strftime &(Datetime.date 2023 1 1) "%U")
    "strftime %U starts week 1 on a January 1 that is a Sunday")
  (assert-equal test
    &@"08"
    &(Datetime.strftime &(Datetime.date 2024 3 1) "%U")
    "strftime %U is leap-aware after February")
  (assert-equal test
    &@"53"
    &(Datetime.strftime &(Datetime.date 2023 12 31) "%U")
    "strftime %U reaches week 53 on a year-ending Sunday")
  (assert-equal test
    &@"01"
    &(Datetime.strftime &(Datetime.date 2024 1 1) "%W")
    "strftime %W starts week 1 on a January 1 that is a Monday")
  (assert-equal test
    &@"00"
    &(Datetime.strftime &(Datetime.date 2023 1 1) "%W")
    "strftime %W puts a leading Sunday before the first Monday in week 0")
  (assert-equal test
    &@"09"
    &(Datetime.strftime &(Datetime.date 2024 3 1) "%W")
    "strftime %W is leap-aware after February")
  (assert-equal test
    &@"52"
    &(Datetime.strftime &(Datetime.date 2023 12 31) "%W")
    "strftime %W counts a year-ending Sunday in the preceding Monday week")

  (assert-equal test
    &[2024 11 5]
    &(Datetime.isocalendar &(Datetime.date 2024 3 15))
    "isocalendar returns [iso-year iso-week iso-weekday] for a mid-year date")
  (assert-equal test
    &[2022 52 7]
    &(Datetime.isocalendar &(Datetime.date 2023 1 1))
    "isocalendar rolls a leading Sunday back into the previous ISO year")
  (assert-equal test
    &[2025 1 1]
    &(Datetime.isocalendar &(Datetime.date 2024 12 30))
    "isocalendar rolls a trailing Monday forward into the next ISO year")
  (assert-equal test
    &[2020 53 5]
    &(Datetime.isocalendar &(Datetime.date 2021 1 1))
    "isocalendar reports week 53 for a 53-week year")
  (assert-equal test
    &@"2024"
    &(Datetime.strftime &(Datetime.date 2024 1 1) "%G")
    "strftime %G matches the calendar year mid-week")
  (assert-equal test
    &@"01"
    &(Datetime.strftime &(Datetime.date 2024 1 1) "%V")
    "strftime %V zero-pads an early week")
  (assert-equal test
    &@"1"
    &(Datetime.strftime &(Datetime.date 2024 1 1) "%u")
    "strftime %u renders Monday as 1")
  (assert-equal test
    &@"7"
    &(Datetime.strftime &(Datetime.date 2023 1 1) "%u")
    "strftime %u renders Sunday as 7")
  (assert-equal test
    &@"2022"
    &(Datetime.strftime &(Datetime.date 2023 1 1) "%G")
    "strftime %G rolls back to the previous ISO year on a leading Sunday")
  (assert-equal test
    &@"52"
    &(Datetime.strftime &(Datetime.date 2023 1 1) "%V")
    "strftime %V is week 52 of 2022 for 2023-01-01")
  (assert-equal test
    &@"2025"
    &(Datetime.strftime &(Datetime.date 2024 12 30) "%G")
    "strftime %G rolls forward to the next ISO year on a trailing Monday")
  (assert-equal test
    &@"01"
    &(Datetime.strftime &(Datetime.date 2024 12 30) "%V")
    "strftime %V is week 01 of 2025 for 2024-12-30")
  (assert-equal test
    &@"53"
    &(Datetime.strftime &(Datetime.date 2021 1 1) "%V")
    "strftime %V reaches week 53 in a 53-week year")
  (assert-equal test
    &@"2024-03-15"
    &(Datetime.strftime &(Datetime.date 2024 3 15) "%F")
    "strftime %F expands to an ISO date")
  (assert-equal test
    &@"00:00:00"
    &(Datetime.strftime &(Datetime.date 2024 3 15) "%T")
    "strftime %T expands to 24-hour time")
  (assert-equal test
    &@"00:00"
    &(Datetime.strftime &(Datetime.date 2024 3 15) "%R")
    "strftime %R is 24-hour time without seconds")
  (assert-equal test
    &@"03/15/24"
    &(Datetime.strftime &(Datetime.date 2024 3 15) "%D")
    "strftime %D is a US-style date")
  (assert-equal test
    &@"12:00:00 AM"
    &(Datetime.strftime &(Datetime.date 2024 3 15) "%r")
    "strftime %r is 12-hour time with AM/PM")
  (assert-equal test
    &@"Mar"
    &(Datetime.strftime &(Datetime.date 2024 3 15) "%h")
    "strftime %h aliases the abbreviated month name")
  (assert-equal test
    &(Result.Success (Datetime.date 2024 3 15))
    &(Datetime.strptime "2024-03-15 11" "%Y-%m-%d %V")
    "strptime consumes %V without disturbing the parsed date")
  (assert-equal test
    &(Result.Success (Datetime.date 2024 3 15))
    &(Datetime.strptime "2024 2024-03-15 5" "%G %Y-%m-%d %u")
    "strptime consumes %G and %u without disturbing the parsed date")
  (assert-equal test
    &(Result.Success (Datetime.date 2024 3 15))
    &(Datetime.strptime "2024-03-15" "%F")
    "strptime parses %F, which expands to %Y-%m-%d")
  (assert-equal test
    &(Result.Success (Datetime.date 2024 3 15))
    &(Datetime.strptime "03/15/24" "%D")
    "strptime parses %D, which expands to %m/%d/%y")

  (assert-true test
    (> &(Datetime.date 2024 3 16) &(Datetime.date 2024 3 15))
    "later date is greater")
  (assert-true test
    (< &(Datetime.date 2024 3 14) &(Datetime.date 2024 3 15))
    "earlier date is less")

  (assert-equal test
    &@"00:05:00"
    &(Datetime.isotime
      &(Duration.add
        &(Datetime.init 2024
                        1
                        1
                        (Maybe.Just 0)
                        (Maybe.Just 0)
                        (Maybe.Just 0)
                        (Maybe.Nothing)
                        (Maybe.Nothing))
        &(Duration.minutes 5)))
    "Duration.add 5 minutes")
  (assert-equal test
    &@"02:00:00"
    &(Datetime.isotime
      &(Duration.add
        &(Datetime.init 2024
                        1
                        1
                        (Maybe.Just 0)
                        (Maybe.Just 0)
                        (Maybe.Just 0)
                        (Maybe.Nothing)
                        (Maybe.Nothing))
        &(Duration.hours 2)))
    "Duration.add 2 hours")
  (assert-equal test
    2
    @(Datetime.day
      &(Duration.add
        &(Datetime.init 2024
                        1
                        1
                        (Maybe.Just 0)
                        (Maybe.Just 0)
                        (Maybe.Just 0)
                        (Maybe.Nothing)
                        (Maybe.Nothing))
        &(Duration.days 1)))
    "Duration.add 1 day advances the day")
  (assert-equal test
    &@"23:55:00"
    &(Datetime.isotime
      &(Duration.sub
        &(Datetime.init 2024
                        1
                        2
                        (Maybe.Just 0)
                        (Maybe.Just 0)
                        (Maybe.Just 0)
                        (Maybe.Nothing)
                        (Maybe.Nothing))
        &(Duration.minutes 5)))
    "Duration.sub 5 minutes wraps back")

  (assert-equal test
    &(Result.Success (Datetime.date 2024 3 15))
    &(Datetime.strptime "2024-03-15" "%Y-%m-%d")
    "strptime parses %Y-%m-%d")

  (assert-equal test
    &(Result.Success
      (Datetime.init 2024
                     3
                     15
                     (Maybe.Just 14)
                     (Maybe.Just 30)
                     (Maybe.Just 45)
                     (Maybe.Nothing)
                     (Maybe.Nothing)))
    &(Datetime.strptime "2024-03-15 14:30:45" "%Y-%m-%d %H:%M:%S")
    "strptime parses date and time")

  (assert-equal test
    2024
    (match (Datetime.strptime "24-03-15" "%y-%m-%d")
      (Result.Success dt) @(Datetime.year &dt)
      (Result.Error _) -1)
    "strptime %y parses 24 as 2024")
  (assert-equal test
    1999
    (match (Datetime.strptime "99-01-01" "%y-%m-%d")
      (Result.Success dt) @(Datetime.year &dt)
      (Result.Error _) -1)
    "strptime %y parses 99 as 1999")

  (assert-equal test
    3
    (match (Datetime.strptime "15 Mar 2024" "%d %b %Y")
      (Result.Success dt) @(Datetime.month &dt)
      (Result.Error _) -1)
    "strptime %b parses abbreviated month")

  (assert-equal test
    3
    (match (Datetime.strptime "March 15, 2024" "%B %d, %Y")
      (Result.Success dt) @(Datetime.month &dt)
      (Result.Error _) -1)
    "strptime %B parses full month name")

  (assert-equal test
    14
    (match (Datetime.strptime "02:30 PM" "%I:%M %p")
      (Result.Success dt) (Maybe.from @(Datetime.hours &dt) 0)
      (Result.Error _) -1)
    "strptime %I %p parses 02 PM as 14")
  (assert-equal test
    2
    (match (Datetime.strptime "02:30 AM" "%I:%M %p")
      (Result.Success dt) (Maybe.from @(Datetime.hours &dt) 0)
      (Result.Error _) -1)
    "strptime %I %p parses 02 AM as 2")
  (assert-equal test
    0
    (match (Datetime.strptime "12:00 AM" "%I:%M %p")
      (Result.Success dt) (Maybe.from @(Datetime.hours &dt) -1)
      (Result.Error _) -2)
    "strptime %I %p parses 12 AM as 0")
  (assert-equal test
    12
    (match (Datetime.strptime "12:00 PM" "%I:%M %p")
      (Result.Success dt) (Maybe.from @(Datetime.hours &dt) -1)
      (Result.Error _) -2)
    "strptime %I %p parses 12 PM as 12")

  (assert-equal test
    123456789
    (match (Datetime.strptime "14:30:00.123456789" "%H:%M:%S.%n")
      (Result.Success dt) (Maybe.from @(Datetime.nanoseconds &dt) 0)
      (Result.Error _) -1)
    "strptime %n parses nanoseconds")

  (assert-true test
    (match (Datetime.strptime "2024-03-15 14:30:00 +0530" "%Y-%m-%d %H:%M:%S %z")
      (Result.Success dt)
        (= 19800l
           @(Timezone.delta &(Maybe.from @(Datetime.tz &dt) (Timezone.zero))))
      (Result.Error _) false)
    "strptime %z parses +0530 offset")
  (assert-true test
    (match (Datetime.strptime "2024-03-15 14:30:00 -0800" "%Y-%m-%d %H:%M:%S %z")
      (Result.Success dt)
        (= -28800l
           @(Timezone.delta &(Maybe.from @(Datetime.tz &dt) (Timezone.zero))))
      (Result.Error _) false)
    "strptime %z parses -0800 offset")

  (assert-true test
    (match (Datetime.strptime "2024-03-15 UTC" "%Y-%m-%d %Z")
      (Result.Success dt)
        (= "UTC"
           (Timezone.name &(Maybe.from @(Datetime.tz &dt) (Timezone.zero))))
      (Result.Error _) false)
    "strptime %Z parses timezone name")

  (assert-equal test
    &(Result.Success (Datetime.date 2024 3 15))
    &(Datetime.strptime "Fri 2024-03-15" "%a %Y-%m-%d")
    "strptime %a parses and discards abbreviated weekday")

  (assert-equal test
    &(Result.Success (Datetime.date 2024 3 15))
    &(Datetime.strptime "Friday 2024-03-15" "%A %Y-%m-%d")
    "strptime %A parses and discards full weekday")

  (assert-equal test
    &(Result.Success (Datetime.date 2024 3 15))
    &(Datetime.strptime "100% 2024-03-15" "100%% %Y-%m-%d")
    "strptime %% matches literal percent")

  (assert-equal test
    &(Result.Success (Datetime.date 2024 3 15))
    &(Datetime.strptime "2024-03-15" "%x")
    "strptime %x parses ISO date")

  (assert-equal test
    14
    (match (Datetime.strptime "14:30:45" "%X")
      (Result.Success dt) (Maybe.from @(Datetime.hours &dt) 0)
      (Result.Error _) -1)
    "strptime %X parses ISO time hours")
  (assert-equal test
    30
    (match (Datetime.strptime "14:30:45" "%X")
      (Result.Success dt) (Maybe.from @(Datetime.minutes &dt) 0)
      (Result.Error _) -1)
    "strptime %X parses ISO time minutes")
  (assert-equal test
    45
    (match (Datetime.strptime "14:30:45" "%X")
      (Result.Success dt) (Maybe.from @(Datetime.seconds &dt) 0)
      (Result.Error _) -1)
    "strptime %X parses ISO time seconds")

  (assert-equal test
    &(Result.Success
      (Datetime.init 2024
                     3
                     15
                     (Maybe.Just 14)
                     (Maybe.Just 30)
                     (Maybe.Just 45)
                     (Maybe.Nothing)
                     (Maybe.Nothing)))
    &(Datetime.strptime "Fri Mar 15 14:30:45 2024" "%c")
    "strptime %c parses locale datetime")

  (assert-equal test
    &(Result.Success
      (Datetime.init 2024
                     3
                     15
                     (Maybe.Just 14)
                     (Maybe.Just 30)
                     (Maybe.Just 45)
                     (Maybe.Nothing)
                     (Maybe.Nothing)))
    &(Datetime.strptime
      &(Datetime.strftime
        &(Datetime.init 2024
                        3
                        15
                        (Maybe.Just 14)
                        (Maybe.Just 30)
                        (Maybe.Just 45)
                        (Maybe.Nothing)
                        (Maybe.Nothing))
        "%c")
      "%c")
    "strptime %c roundtrips with strftime")

  (assert-true test
    (Result.error? &(Datetime.strptime "not-a-date" "%Y-%m-%d"))
    "strptime returns error on bad input")
  (assert-true test
    (Result.error? &(Datetime.strptime "2024-03-15" "%Y/%m/%d"))
    "strptime returns error on format mismatch")

  (assert-equal test
    &(Result.Success (Datetime.date 2024 3 15))
    &(Datetime.strptime
      &(Datetime.strftime &(Datetime.date 2024 3 15) "%Y-%m-%d")
      "%Y-%m-%d")
    "strptime roundtrips with strftime for date")
  (assert-equal test
    &(Result.Success
      (Datetime.init 2024
                     3
                     15
                     (Maybe.Just 14)
                     (Maybe.Just 30)
                     (Maybe.Just 45)
                     (Maybe.Nothing)
                     (Maybe.Nothing)))
    &(Datetime.strptime
      &(Datetime.strftime
        &(Datetime.init 2024
                        3
                        15
                        (Maybe.Just 14)
                        (Maybe.Just 30)
                        (Maybe.Just 45)
                        (Maybe.Nothing)
                        (Maybe.Nothing))
        "%Y-%m-%d %H:%M:%S")
      "%Y-%m-%d %H:%M:%S")
    "strptime roundtrips with strftime for datetime")

  (assert-true test
    (= &(Datetime.date 2024 3 15) &(Datetime.date 2024 3 15))
    "equal dates are equal")
  (assert-false test
    (= &(Datetime.date 2024 1 15) &(Datetime.date 2024 2 15))
    "different months are not equal")
  (assert-true test
    (> &(Datetime.date 2024 3 15) &(Datetime.date 2024 2 15))
    "greater-than with same year different month")
  (assert-true test
    (< &(Datetime.date 2023 12 31) &(Datetime.date 2024 1 1))
    "less-than with year priority over month")
  (assert-false test
    (> &(Datetime.date 2024 3 15) &(Datetime.date 2024 3 15))
    "equal datetimes return false for >")
  (assert-false test
    (< &(Datetime.date 2024 3 15) &(Datetime.date 2024 3 15))
    "equal datetimes return false for <")

  (assert-equal test
    &@"23:59:59"
    &(Datetime.isotime
      &(Datetime.add-seconds
        &(Datetime.init 2024
                        1
                        2
                        (Maybe.Just 0)
                        (Maybe.Just 0)
                        (Maybe.Just 0)
                        (Maybe.Nothing)
                        (Maybe.Nothing))
        -1))
    "subtract 1 second from 00:00:00")
  (assert-equal test
    &@"22:58:59"
    &(Datetime.isotime
      &(Datetime.add-seconds
        &(Datetime.init 2024
                        1
                        2
                        (Maybe.Just 0)
                        (Maybe.Just 0)
                        (Maybe.Just 0)
                        (Maybe.Nothing)
                        (Maybe.Nothing))
        -3661))
    "subtract 3661 seconds (1h1m1s) from 00:00:00")

  (assert-equal test
    0
    (Datetime.diff &(Datetime.date 2024 3 15) &(Datetime.date 2024 3 15))
    "diff: same date is 0")
  (assert-equal test
    86400
    (Datetime.diff &(Datetime.date 2024 3 16) &(Datetime.date 2024 3 15))
    "diff: one day apart is 86400")
  (assert-equal test
    -86400
    (Datetime.diff &(Datetime.date 2024 3 15) &(Datetime.date 2024 3 16))
    "diff: reversed order is negative")
  (assert-equal test
    3600
    (Datetime.diff
      &(Datetime.init 2024
                      3
                      15
                      (Maybe.Just 1)
                      (Maybe.Just 0)
                      (Maybe.Just 0)
                      (Maybe.Nothing)
                      (Maybe.Nothing))
      &(Datetime.init 2024
                      3
                      15
                      (Maybe.Just 0)
                      (Maybe.Just 0)
                      (Maybe.Just 0)
                      (Maybe.Nothing)
                      (Maybe.Nothing)))
    "diff: one hour apart is 3600")
  (assert-equal test
    90061
    (Datetime.diff
      &(Datetime.init 2024
                      3
                      16
                      (Maybe.Just 1)
                      (Maybe.Just 1)
                      (Maybe.Just 1)
                      (Maybe.Nothing)
                      (Maybe.Nothing))
      &(Datetime.init 2024
                      3
                      15
                      (Maybe.Just 0)
                      (Maybe.Just 0)
                      (Maybe.Just 0)
                      (Maybe.Nothing)
                      (Maybe.Nothing)))
    "diff: 1 day 1 hour 1 minute 1 second = 90061")
  (assert-equal test
    (* 365 86400)
    (Datetime.diff &(Datetime.date 2023 1 1) &(Datetime.date 2022 1 1))
    "diff: non-leap year is 365 days")
  (assert-equal test
    (* 366 86400)
    (Datetime.diff &(Datetime.date 2025 1 1) &(Datetime.date 2024 1 1))
    "diff: leap year 2024 has 366 days")

  (assert-equal test
    &(Datetime.date 2024 2 15)
    &(Datetime.add-months &(Datetime.date 2024 1 15) 1)
    "add-months: Jan to Feb")
  (assert-equal test
    &(Datetime.date 2024 2 29)
    &(Datetime.add-months &(Datetime.date 2024 1 31) 1)
    "add-months: Jan 31 to Feb 29 (leap year clamp)")
  (assert-equal test
    &(Datetime.date 2023 2 28)
    &(Datetime.add-months &(Datetime.date 2023 1 31) 1)
    "add-months: Jan 31 to Feb 28 (non-leap year clamp)")
  (assert-equal test
    &(Datetime.date 2024 4 30)
    &(Datetime.add-months &(Datetime.date 2024 3 31) 1)
    "add-months: Mar 31 to Apr 30 (30-day month clamp)")
  (assert-equal test
    &(Datetime.date 2025 1 15)
    &(Datetime.add-months &(Datetime.date 2024 12 15) 1)
    "add-months: Dec to Jan crosses year")
  (assert-equal test
    &(Datetime.date 2024 2 15)
    &(Datetime.add-months &(Datetime.date 2024 3 15) -1)
    "add-months: negative, Mar to Feb")
  (assert-equal test
    &(Datetime.date 2023 12 15)
    &(Datetime.add-months &(Datetime.date 2024 1 15) -1)
    "add-months: negative, Jan to Dec crosses year")
  (assert-equal test
    &(Datetime.date 2025 1 15)
    &(Datetime.add-months &(Datetime.date 2024 1 15) 12)
    "add-months: 12 months = 1 year")
  (assert-equal test
    &(Datetime.date 2022 1 15)
    &(Datetime.add-months &(Datetime.date 2024 1 15) -24)
    "add-months: -24 months = -2 years")
  (assert-equal test
    &(Datetime.date 2024 7 31)
    &(Datetime.add-months &(Datetime.date 2024 5 31) 2)
    "add-months: May 31 + 2 = Jul 31 (no clamp needed)")
  (assert-equal test
    &(Datetime.init 2024
                    2
                    15
                    (Maybe.Just 10)
                    (Maybe.Just 30)
                    (Maybe.Just 45)
                    (Maybe.Nothing)
                    (Maybe.Nothing))
    &(Datetime.add-months
      &(Datetime.init 2024
                      1
                      15
                      (Maybe.Just 10)
                      (Maybe.Just 30)
                      (Maybe.Just 45)
                      (Maybe.Nothing)
                      (Maybe.Nothing))
      1)
    "add-months: preserves time components")

  (assert-equal test
    &(Datetime.date 2025 3 15)
    &(Datetime.add-years &(Datetime.date 2024 3 15) 1)
    "add-years: simple +1")
  (assert-equal test
    &(Datetime.date 2025 2 28)
    &(Datetime.add-years &(Datetime.date 2024 2 29) 1)
    "add-years: Feb 29 to non-leap year clamps to 28")
  (assert-equal test
    &(Datetime.date 2028 2 29)
    &(Datetime.add-years &(Datetime.date 2024 2 29) 4)
    "add-years: Feb 29 to next leap year stays 29")
  (assert-equal test
    &(Datetime.date 2023 3 15)
    &(Datetime.add-years &(Datetime.date 2024 3 15) -1)
    "add-years: negative, -1 year")
  (assert-equal test
    &(Datetime.date 2023 2 28)
    &(Datetime.add-years &(Datetime.date 2024 2 29) -1)
    "add-years: Feb 29 backward to non-leap clamps to 28")
  (assert-equal test
    &(Datetime.date 2024 7 15)
    &(Datetime.add-years &(Datetime.date 2024 7 15) 0)
    "add-years: +0 is identity")
  (assert-equal test
    &(Datetime.date 1900 2 28)
    &(Datetime.add-years &(Datetime.date 2000 2 29) -100)
    "add-years: 2000 Feb 29 -100 to 1900 (not leap) clamps to 28")
  (assert-equal test
    &(Datetime.date 2400 2 29)
    &(Datetime.add-years &(Datetime.date 2000 2 29) 400)
    "add-years: 2000 Feb 29 +400 to 2400 (leap) stays 29")
  (assert-equal test
    &(Datetime.init 2025
                    3
                    15
                    (Maybe.Just 14)
                    (Maybe.Just 30)
                    (Maybe.Just 0)
                    (Maybe.Nothing)
                    (Maybe.Nothing))
    &(Datetime.add-years
      &(Datetime.init 2024
                      3
                      15
                      (Maybe.Just 14)
                      (Maybe.Just 30)
                      (Maybe.Just 0)
                      (Maybe.Nothing)
                      (Maybe.Nothing))
      1)
    "add-years: preserves time components")

  (assert-equal test
    &(Duration.days 2)
    &(Duration.between &(Datetime.date 2024 1 3) &(Datetime.date 2024 1 1))
    "between: positive whole-day difference")
  (assert-equal test
    &(Duration.days -2)
    &(Duration.between &(Datetime.date 2024 1 1) &(Datetime.date 2024 1 3))
    "between: negative difference")
  (assert-true test
    (Duration.zero?
      &(Duration.between &(Datetime.date 2024 1 1) &(Datetime.date 2024 1 1)))
    "between: identical datetimes is zero")
  (assert-equal test
    &(Duration.seconds 3661)
    &(Duration.between
      &(Datetime.init 2024
                      1
                      1
                      (Maybe.Just 1)
                      (Maybe.Just 1)
                      (Maybe.Just 1)
                      (Maybe.Nothing)
                      (Maybe.Nothing))
      &(Datetime.init 2024
                      1
                      1
                      (Maybe.Just 0)
                      (Maybe.Just 0)
                      (Maybe.Just 0)
                      (Maybe.Nothing)
                      (Maybe.Nothing)))
    "between: sub-day difference in seconds")

  (assert-equal test
    3600
    (Duration.to-seconds &(Duration.hours 1))
    "to-seconds: exact")
  (assert-equal test
    1
    (Duration.to-minutes &(Duration.seconds 90))
    "to-minutes: truncates positive remainder")
  (assert-equal test
    0
    (Duration.to-minutes &(Duration.seconds 59))
    "to-minutes: below one minute is zero")
  (assert-equal test
    -1
    (Duration.to-minutes &(Duration.seconds -90))
    "to-minutes: truncates toward zero for negatives")
  (assert-equal test
    1
    (Duration.to-hours &(Duration.minutes 90))
    "to-hours: truncates remainder")
  (assert-equal test
    1
    (Duration.to-days &(Duration.hours 25))
    "to-days: truncates remainder")
  (assert-equal test
    7
    (Duration.to-days &(Duration.weeks 1))
    "to-days: one week is seven days")

  (assert-equal test
    &(Duration.seconds 90)
    &(Duration.plus &(Duration.minutes 1) &(Duration.seconds 30))
    "plus: sums two deltas")
  (assert-equal test
    &(Duration.seconds 30)
    &(Duration.minus &(Duration.minutes 1) &(Duration.seconds 30))
    "minus: difference of two deltas")
  (assert-equal test
    &(Duration.seconds -30)
    &(Duration.minus &(Duration.seconds 30) &(Duration.minutes 1))
    "minus: can go negative")
  (assert-equal test
    &(Duration.seconds -60)
    &(Duration.negate &(Duration.minutes 1))
    "negate: flips a positive delta")
  (assert-equal test
    &(Duration.minutes 1)
    &(Duration.negate &(Duration.seconds -60))
    "negate: flips a negative delta")
  (assert-equal test
    &(Duration.minutes 3)
    &(Duration.scale &(Duration.minutes 1) 3)
    "scale: multiplies by a factor")
  (assert-equal test
    &(Duration.seconds 0)
    &(Duration.scale &(Duration.minutes 1) 0)
    "scale: by zero yields the zero delta")
  (assert-equal test
    &(Duration.minutes 3)
    &(Duration.mul &(Duration.minutes 1) 3)
    "mul: aliases scale")

  (assert-true test
    (Duration.= &(Duration.minutes 1) &(Duration.seconds 60))
    "=: equal durations from different units")
  (assert-false test
    (Duration.= &(Duration.minutes 1) &(Duration.seconds 61))
    "=: unequal durations")
  (assert-true test
    (Duration.< &(Duration.seconds 30) &(Duration.minutes 1))
    "<: shorter is less")
  (assert-false test
    (Duration.< &(Duration.minutes 1) &(Duration.seconds 30))
    "<: longer is not less")
  (assert-true test
    (Duration.> &(Duration.minutes 1) &(Duration.seconds 30))
    ">: longer is greater")
  (assert-false test
    (Duration.> &(Duration.seconds 30) &(Duration.minutes 1))
    ">: shorter is not greater")
  (assert-true test
    (Duration.zero? &(Duration.seconds 0))
    "zero?: the zero delta")
  (assert-false test
    (Duration.zero? &(Duration.seconds 1))
    "zero?: a non-zero delta")
  (assert-true test (Duration.pos? &(Duration.seconds 1)) "pos?: positive delta")
  (assert-false test
    (Duration.pos? &(Duration.seconds -1))
    "pos?: negative delta is not positive")
  (assert-false test
    (Duration.pos? &(Duration.seconds 0))
    "pos?: zero is not positive")
  (assert-true test
    (Duration.neg? &(Duration.seconds -1))
    "neg?: negative delta")
  (assert-false test
    (Duration.neg? &(Duration.seconds 1))
    "neg?: positive delta is not negative")
  (assert-false test
    (Duration.neg? &(Duration.seconds 0))
    "neg?: zero is not negative")

  (assert-equal test
    &@"0s"
    &(Duration.str &(Duration.seconds 0))
    "str: zero delta")
  (assert-equal test
    &@"4s"
    &(Duration.str &(Duration.seconds 4))
    "str: single second")
  (assert-equal test
    &@"3m"
    &(Duration.str &(Duration.minutes 3))
    "str: single minute")
  (assert-equal test
    &@"2h"
    &(Duration.str &(Duration.hours 2))
    "str: single hour")
  (assert-equal test &@"1d" &(Duration.str &(Duration.days 1)) "str: single day")
  (assert-equal test
    &@"1d 2h 3m 4s"
    &(Duration.str &(Duration.seconds 93784))
    "str: multi-unit")
  (assert-equal test
    &@"1h 5s"
    &(Duration.str &(Duration.seconds 3605))
    "str: omits zero components")
  (assert-equal test
    &@"-30s"
    &(Duration.str &(Duration.seconds -30))
    "str: negative single unit")
  (assert-equal test
    &@"-1d 2h 3m 4s"
    &(Duration.str &(Duration.seconds -93784))
    "str: negative multi-unit"))
